rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All reads/writes go through the trusted Express backend, which authenticates
    // to Firestore using the Firebase Admin SDK (service account) — that path
    // bypasses these rules entirely. Direct client/browser access is denied here
    // as defense-in-depth, since the browser never talks to Firestore directly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
